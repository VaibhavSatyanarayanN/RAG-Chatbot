# Dockerfile for backend FastAPI app
# Build from backend root (backend/ folder)

FROM python:3.12-slim

# avoid writing .pyc files and use unbuffered output
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# system deps (if needed): e.g., build tools for packages with C extensions
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
 && rm -rf /var/lib/apt/lists/*

# install python deps
COPY requirements.txt /app/requirements.txt
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# copy backend source code
COPY . /app

# expose FastAPI default port
EXPOSE 8000

# run uvicorn for the app package app.main
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
